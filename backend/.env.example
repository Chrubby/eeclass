PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=classroom_data
OPENAI_API_KEY=
# 選填，預設 gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# 忘記密碼：重設信內連結之前端網址（勿結尾斜線）
FRONTEND_URL=http://127.0.0.1:5173
# 重設 token 有效分鐘數，預設 60
PASSWORD_RESET_EXPIRE_MINUTES=60

# 選填：寄信用 SMTP（未設定時仍會建立 token，開發環境會在後端主控台印出重設連結）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
